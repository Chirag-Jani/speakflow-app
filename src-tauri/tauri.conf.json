{
  "productName": "SpeakFlow",
  "version": "1.0.0",
  "identifier": "com.speakflow.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SpeakFlow",
        "width": 420,
        "height": 680,
        "visible": true,
        "resizable": false,
        "decorations": true,
        "backgroundColor": "#0c0c0c"
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "dmg",
    "icon": ["icons/icon.icns", "icons/icon.ico", "icons/icon.png"],
    "macOS": {
      "entitlements": "entitlements.plist",
      "signingIdentity": "-",
      "infoPlist": "Info.plist"
    }
  }
}
